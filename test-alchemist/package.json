{
  "name": "test-alchemist",
  "version": "1.0.0",
  "description": "Test Alchemist – AI-powered QA tool that turns requirements into test cases, automation scripts and CI pipelines",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init": "node scripts/init.js",
    "doctor": "node scripts/doctor.js",
    "eval": "node scripts/eval.js",
    "package": "node scripts/package.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "install:playwright": "playwright install --with-deps chromium",
    "check:deploy": "node scripts/check-deploy.js",
    "build:s3": "node scripts/build-s3.js",
    "upload:s3": "node scripts/upload-s3.js",
    "package:eb": "node scripts/package-eb.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.24.1",
    "archiver": "^6.0.1",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "openai": "^6.39.0",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^6.1.0",
    "pdfkit": "^0.18.0",
    "playwright": "^1.60.0",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "nodemon": "^3.0.2"
  }
}
