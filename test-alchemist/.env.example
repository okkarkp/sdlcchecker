# ─── AI Provider Keys (set whichever you use — all can coexist) ────────────────
# Claude  → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ChatGPT → https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Gemini  → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Custom / OpenAI-compatible endpoint (gateway · local model · Azure) ────────
# One provider for any OpenAI-compatible API. Also settable live in ⚙ Settings.
#   • Internal gateway / local (Ollama, vLLM, LM Studio): set BASE_URL + MODEL (+ KEY if required)
#   • Azure OpenAI: BASE_URL=https://<res>.openai.azure.com/openai/deployments/<deployment>
#                   MODEL=<deployment name>,  set API_VERSION (e.g. 2024-06-01)
CUSTOM_AI_BASE_URL=
CUSTOM_AI_KEY=
CUSTOM_AI_MODEL=
CUSTOM_AI_API_VERSION=

# ─── Application ───────────────────────────────────────────────────────────────
PORT=3000
APP_NAME=Test Alchemist
# Default base URL of the application under test (used as a fallback for
# Playwright generation and the browser agent when none is supplied in the UI).
APP_BASE_URL=
# Path to a real Chrome executable for the Browser Agent (headed runs).
# Optional — if unset or not found, Playwright's bundled Chromium is used.
CHROME_PATH=
# NOTE: login is NO LONGER taken from fixed env defaults — the tool is used across
# different projects, so credentials come from each TEST CASE's own data (username /
# password / uin / uen) for the app/URL under test, and the Digital Twin crawler takes
# its identity from the crawl config. These APP_* vars are deprecated for login and are
# ignored by the Browser Agent / crawler; leave them blank.
APP_USERNAME=
APP_PASSWORD=
APP_UIN=
APP_UEN=
# Max turns (LLM calls) the Browser Agent takes per run. Each turn the agent now plans
# a BATCH of actions (browser-use style), so far fewer turns are needed. Default 30.
AGENT_MAX_TURNS=30
# Max actions the agent may batch into a single turn (e.g. fill all login fields + submit
# in one LLM call). Higher = fewer round-trips/faster; lower = more cautious. Default 8.
AGENT_MAX_ACTIONS=8
# Draw browser-use-style highlight boxes + index labels over interactive elements in the
# live headed browser (and a flash pulse on each click/fill). Set to 0 to disable. Default on.
AGENT_HIGHLIGHT=1
# Model used for converting recordings into repo scripts (mechanical code-gen).
# Defaults to a faster model (Sonnet for Claude) so script creation isn't slow.
# Set to claude-opus-4-8 if you want maximum quality at the cost of speed.
CONVERSION_MODEL=
# UUID the Browser Agent types into any UUID/GUID field. Set a specific UUID,
# or "generate" for a fresh v4 each run. Test steps can also use {{uuid}} (this
# value) or say "generate new UUID" (a fresh v4). Defaults to a built-in UUID.
TEST_UUID=

# ─── Digital Twin (optional) ───────────────────────────────────────────────────
# Structured, crawled model of the app used to ground test generation.
# Secret CI/CD uses to trigger a post-deploy re-crawl (can also be set in the UI).
TWIN_WEBHOOK_SECRET=
# Auto-discovery BFS depth, route cap, per-page timeout (ms), API observe window (ms).
TWIN_MAX_DEPTH=5
TWIN_MAX_ROUTES=200
TWIN_PAGE_TIMEOUT=25000
TWIN_API_WAIT_MS=3000
# SPA crawling: max navigation elements clicked per page (router/button-driven nav),
# and an overall wall-clock budget (ms) so a large app can't crawl forever.
TWIN_MAX_CLICKS=40
TWIN_BUDGET_MS=900000

# ─── Authentication (local accounts) ───────────────────────────────────────────
# OFF by default (open, like a local tool). Turn ON for a shared/central deploy.
# Enabled automatically when AUTH_ADMIN_* are set, or force with AUTH_ENABLED=true.
# On first boot an admin is seeded from these; add more users via lib/auth addUser.
AUTH_ENABLED=
AUTH_ADMIN_USER=
AUTH_ADMIN_PASSWORD=
# Optional: stable secret for signing session cookies (else auto-generated in data/).
# Set this in multi-host/redeploy setups so sessions survive. Keep it secret.
AUTH_SESSION_SECRET=
# Session lifetime in hours (default 12).
AUTH_SESSION_TTL_HOURS=

# Restrict access by IP (comma-separated). Empty = open (localhost always allowed).
ALLOWED_IPS=
# CORS origin for the API (default: *)
ALLOWED_ORIGIN=*

# ─── GitLab ────────────────────────────────────────────────────────────────────
# Your GitLab instance URL (default: https://gitlab.com)
GITLAB_URL=https://gitlab.com
# Personal Access Token with api scope
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# Project ID (found in Project > Settings > General)
GITLAB_PROJECT_ID=12345678
# Pipeline trigger token (Project > Settings > CI/CD > Pipeline triggers)
GITLAB_TRIGGER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
# Branch to trigger pipeline on
GITLAB_DEFAULT_BRANCH=main

# ─── Jira ──────────────────────────────────────────────────────────────────────
# The project name shown in the app header is read from this Jira connection.
# Jira Cloud base URL: https://yourorg.atlassian.net
JIRA_BASE_URL=https://yourorg.atlassian.net
# Jira email address (Cloud)
JIRA_EMAIL=your.email@example.com
# Jira API token (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
# Default project key for test management
JIRA_PROJECT_KEY=QA
# Issue type used for test cases. Default "Test" works for plain Jira projects;
# set "Test Case" / "Test Xray" etc. to match your project.
JIRA_TEST_ISSUE_TYPE=Test

# ─── Xray (optional — only if your Jira project uses Xray) ──────────────────────
# Without these, test cases are created as plain Jira cards with the steps
# embedded in the description. Found in Jira → Apps → Manage Apps → Xray → API Keys
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
# Xray test repository folder for uploaded test cases (e.g. /Regression)
JIRA_TEST_PATH=

# ─── Automation repo (optional — for Playwright generation context) ────────────
# Path to the existing automation repo. Empty = no repo context (the
# Playwright page reports a generic, unconnected state).
AUTOMATION_REPO_PATH=
# Folder names inside that repo (defaults shown). These drive the
# "N page objects · N specs · prompts loaded" status on the Playwright page.
PAGE_OBJECTS_DIR=pages
SPECS_DIR=tests
# Instructions / conversion prompt the generator reads, repo-relative.
# Used both for Playwright generation and when converting recorded agent
# sessions into repo scripts.
PROMPT_FILE=.github/CONVERSION_PROMPT.md
# Optional extra reference files (repo-relative). Leave blank if not used.
LEARNINGS_FILE=
SEED_SPEC=seed.spec.js
LOGIN_PAGE=loginPage.js

# ─── Confluence (optional) ─────────────────────────────────────────────────────
# Falls back to the JIRA_* values above when unset (same Atlassian token works).
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# ─── Testing standards (optional) ──────────────────────────────────────────────
# Point this at a per-project standards JSON to override the bundled default.
TESTING_STANDARDS_PATH=

# ─── Figma (optional) ──────────────────────────────────────────────────────────
FIGMA_ACCESS_TOKEN=figd_xxxxxxxxxxxxxxxxxxxxxxxx
